# 이 파일을 .env 로 복사한 뒤 SWEETBOOK_API_KEY 만 채우면 됩니다. 나머지는 저장소 예시 값 그대로 두어도 됩니다.
# --- SweetBook API ---
SWEETBOOK_API_KEY=
SWEETBOOK_API_BASE_URL=https://api-sandbox.sweetbook.com/v1

SWEETBOOK_DEFAULT_BOOK_SPEC_UID=SQUAREBOOK_HC

# --- 서버 ---
PORT=3001
NODE_ENV=development

# --- MySQL (TypeORM) ---
# docker-compose의 mysql과 동일 계정/DB (호스트에서 nest 실행 시)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=app
DB_PASSWORD=apppass
DB_DATABASE=sweetbook

TYPEORM_SYNC=true
TYPEORM_LOGGING=false

# --- JWT ---
JWT_SECRET=dev-jwt-secret-change-me
JWT_EXPIRES_DAYS=7


# --- npm run seed (선택) ---
# 시드 스크립트(backend/scripts/seed.ts)는 SweetBook API를 호출하지 않습니다.
#
# SEED_ADMIN_ID/EMAIL/PASSWORD, SEED_USER_ID/EMAIL/PASSWORD 는 필수입니다.
# (하드코딩 없이 .env 값만 사용)
# display_name은 시드에서 고정값 사용: 관리자=관리자, 이용자=선생님
#
SEED_ADMIN_ID=00000000-0000-4000-a000-000000000001
SEED_ADMIN_EMAIL=testadmin123@naver.com
SEED_ADMIN_PASSWORD=test123@

SEED_USER_ID=00000000-0000-4000-a000-000000000002
SEED_USER_EMAIL=testuser123@naver.com
SEED_USER_PASSWORD=test123@
#
# SEED_USER_BALANCE_WON — 시드 이용자 잔액(원). 미설정 시 500000.
# SEED_COVER_TEMPLATE_UID — 시드 시 등록할 표지 템플릿 UID(SweetBook).
# SEED_CONTENT_TEMPLATE_UID_1 — 시드 시 등록할 내지 템플릿 UID(필수로 하나).
# SEED_CONTENT_TEMPLATE_UID_2 — 추가 내지 템플릿 UID(선택).
#
SEED_USER_BALANCE_WON=500000
SEED_COVER_TEMPLATE_UID=4MY2fokVjkeY
SEED_CONTENT_TEMPLATE_UID_1=2mi1ao0Z4Vxl
SEED_CONTENT_TEMPLATE_UID_2=
